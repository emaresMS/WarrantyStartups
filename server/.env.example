# Supabase project URL (found in Supabase dashboard → Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co

# JWT secret used to verify Supabase-issued tokens (Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Postgres connection string (Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# Comma-separated list of allowed CORS origins (default: Vite dev server)
CORS_ORIGINS=http://localhost:5173

# Port the Flask dev server listens on
PORT=5000
