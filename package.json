{
  "name": "warranty-startups",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "npm --prefix client run dev",
    "dev:server": "python -m flask --app server.app run --port 5000 --debug",
    "build": "npm --prefix client run build",
    "typecheck": "npm --prefix client run typecheck",
    "lint": "npm --prefix client run lint",
    "test": "node -e \"console.log('No tests yet — added in later phases')\"",
    "setup": "npm --prefix client install"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
